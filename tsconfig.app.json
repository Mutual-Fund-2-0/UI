{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue", "vitest.setup.ts"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM"],
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@v/*": ["./src/views/*"],
      "@t/*": ["./src/types/*"],
      "@r/*": ["./src/router/*"],
      "@s/*": ["./src/services/*"],
      "@c/*": ["./src/components/*"]
    }
  }
}
