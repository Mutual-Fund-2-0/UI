{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.cypress.tsbuildinfo",
    "target": "ES2024",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "types": ["cypress", "@testing-library/cypress", "node"],
    "noEmit": true,
    "isolatedModules": true
  },
  "include": ["./cypress/**/*.ts", "./cypress/**/*.d.ts", "./cypress/**/*.vue", "./cypress/**/*.cy.{js,ts,jsx,tsx}", "./cypress.d.ts"]
}
